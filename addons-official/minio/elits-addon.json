{
  "slug": "minio",
  "name": "MinIO Object Storage",
  "version": "latest",
  "description": "Object storage za Milvus podatke",
  "url": "https://min.io",
  "image": "minio/minio:latest",

  "startup": "application",
  "boot": "auto",
  "init": false,
  "arch": ["amd64"],

  "command": [
    "server",
    "/data",
    "--console-address",
    ":9001"
  ],

  "ports": {
    "9000/tcp": 9000,
    "9001/tcp": 9001
  },

  "environment": {
    "MINIO_ROOT_USER": "minioadmin",
    "MINIO_ROOT_PASSWORD": "minioadmin"
  },

  "volumes": {
    "/data/elits/minio/data": { "bind": "/data", "mode": "rw" }
  },

  "network": "elits-net",
  "ip_address": "31.3.77.7",

  "memory_limit": "2G",
  "cpu_limit": 2,

  "web_ui": {
    "path": "/",
    "title": "MinIO",
    "icon": "mdi:database"
  },

  "dependencies": [],
  "stage": "stable"
}
