{
  "slug": "etcd",
  "name": "etcd Key-Value Store",
  "version": "3.5.5",
  "description": "etcd za Milvus metapodatke",
  "url": "https://etcd.io",
  "image": "quay.io/coreos/etcd:v3.5.5",

  "startup": "application",
  "boot": "auto",
  "init": false,
  "arch": ["amd64"],

  "command": [
    "etcd",
    "-advertise-client-urls=http://0.0.0.0:2379",
    "-listen-client-urls=http://0.0.0.0:2379",
    "--data-dir=/etcd"
  ],

  "ports": {
    "2379/tcp": 2379,
    "2380/tcp": 2380
  },

  "environment": {},

  "volumes": {
    "/data/elits/etcd/data": { "bind": "/etcd", "mode": "rw" }
  },

  "network": "elits-net",
  "ip_address": "31.3.77.6",

  "memory_limit": "1G",
  "cpu_limit": 1,

  "web_ui": {
    "path": "/",
    "title": "etcd",
    "icon": "mdi:database"
  },

  "dependencies": [],
  "stage": "stable"
}
