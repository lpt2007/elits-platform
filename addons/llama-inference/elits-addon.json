{
  "slug": "llama-inference",
  "name": "Qwen AI Inference",
  "version": "0.1.0",
  "description": "35B MoE Model z TurboQuant optimizacijami za ekstrakcijo podatkov",
  "url": "https://github.com/lpt2007/elits-platform",
  "image": "nvidia/cuda:12.4.1-devel-ubuntu22.04",
  
  "startup": "application",
  "boot": "auto",
  "init": false,
  
  "arch": ["amd64"],
  
  "options": {
    "model": "qwen3-35b-a3b.Q4_K_M.gguf",
    "context_length": 32768,
    "n_gpu_layers": 99,
    "n_cpu_moe": 36,
    "cache_type_k": "turbo4",
    "cache_type_v": "turbo3"
  },
  
  "ports": {
    "8080/tcp": null
  },
  
  "devices": ["/dev/nvidia0", "/dev/nvidiactl", "/dev/nvidia-uvm"],
  
  "environment": {
    "API_KEY": "elits-secure-key-2026",
    "HASSIO_TOKEN": "{{SUPERVISOR_TOKEN}}",
    "HASSIO": "31.3.77.1"
  },
  
  "map": [
    "models:ro",
    "share:rw",
    "ssl:ro"
  ],
  
  "volumes": {
    "/data/elits/models": { "bind": "/models", "mode": "ro" },
    "/data/elits/share": { "bind": "/share", "mode": "rw" },
    "/data/elits/addons/llama-inference": { "bind": "/config", "mode": "rw" }
  },
  
  "network": "elits-net",
  "ip_address": "31.3.77.3",
  
  "gpu": true,
  "memory_limit": "24G",
  "cpu_limit": 4,
  
  "cap_add": ["IPC_LOCK"],
  "ulimits": { "memlock": -1 },
  
  "healthcheck": {
    "test": ["CMD", "curl", "-f", "http://localhost:8080/health"],
    "interval": "60s",
    "timeout": "10s",
    "retries": 3
  },
  
  "web_ui": {
    "path": "/",
    "title": "AI Inference Monitor",
    "icon": "mdi:brain"
  },
  
  "dependencies": [],
  "stage": "experimental"
}
